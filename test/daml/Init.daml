-- On-ledger seed for the demo. Run against LocalNet or a Devnet participant:
--   daml script --dar test/.daml/dist/bisik-test-0.1.0.dar \
--     --script-name Init:initialize --ledger-host <host> --ledger-port <port>
-- initialize   : parties + holdings + an open RFQ with two sealed quotes
-- holdingsOnly : parties + holdings only (RFQ/quotes driven live in the UI/demo)
module Init where

import DA.Date (Month(Jan), date)
import DA.Foldable (forA_)
import DA.Time (time)
import Daml.Script
import Bisik

data Parties = Parties
  with
    buyer : Party
    dealerA : Party
    dealerB : Party
    regulator : Party
    cashIssuer : Party
    bondIssuer : Party
  deriving (Eq, Show)

-- Allocate the demo parties and fund them: buyer holds cash, each dealer a bond.
setup : Script (Parties, ContractId Holding, ContractId Holding)
setup = do
  buyer <- allocateParty "Buyer"
  dealerA <- allocateParty "DealerA"
  dealerB <- allocateParty "DealerB"
  regulator <- allocateParty "Regulator"
  cashIssuer <- allocateParty "CashIssuer"
  bondIssuer <- allocateParty "BondIssuer"
  let parties = Parties with buyer; dealerA; dealerB; regulator; cashIssuer; bondIssuer

  _ <- submit cashIssuer do
    createCmd Holding with
      issuer = cashIssuer; owner = buyer; instrument = "USDC"; amount = 5000000.0
  bondA <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerA; instrument = "TBOND30"; amount = 1000.0
  bondB <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerB; instrument = "TBOND30"; amount = 1000.0

  forA_ [ ("buyer", buyer), ("dealerA", dealerA), ("dealerB", dealerB)
        , ("regulator", regulator) ] \(label, p) -> debug (label <> " = " <> show p)
  pure (parties, bondA, bondB)

holdingsOnly : Script Parties
holdingsOnly = do
  (parties, _, _) <- setup
  pure parties

initialize : Script Parties
initialize = do
  (p, bondA, bondB) <- setup

  -- A PRIOR completed trade on a separate instrument (GILT10), fully settled via
  -- Award, so the regulator's post-trade audit trail is non-empty in the demo —
  -- showing both halves of the story at once: sealed pre-trade + auditable post-trade.
  settleCash <- submit p.cashIssuer do
    createCmd Holding with issuer = p.cashIssuer; owner = p.buyer; instrument = "USDC"; amount = 300000.0
  giltA <- submit p.bondIssuer do
    createCmd Holding with issuer = p.bondIssuer; owner = p.dealerA; instrument = "GILT10"; amount = 100.0
  giltB <- submit p.bondIssuer do
    createCmd Holding with issuer = p.bondIssuer; owner = p.dealerB; instrument = "GILT10"; amount = 100.0
  giltRfq <- submit p.buyer do
    createCmd RFQ with
      buyer = p.buyer; regulator = p.regulator
      invitedDealers = [p.dealerA, p.dealerB]
      instrument = "GILT10"; quantity = 100.0; payInstrument = "USDC"
      assetIssuer = Some p.bondIssuer; payIssuer = Some p.cashIssuer
      deadline = Some (time (date 2030 Jan 1) 0 0 0)
  gqA <- submit p.dealerA do
    exerciseCmd giltRfq SubmitQuote with dealer = p.dealerA; price = 190000.0; assetCid = giltA
  gqB <- submit p.dealerB do
    exerciseCmd giltRfq SubmitQuote with dealer = p.dealerB; price = 195000.0; assetCid = giltB
  -- Cheapest ask (dealerA) wins, paid the second price (195000) — atomic DvP, TradeReport → regulator.
  _ <- submit p.buyer do
    exerciseCmd giltRfq Award with quoteCids = [gqA, gqB]; cashCid = settleCash

  -- The LIVE RFQ for the pre-award money shot: TBOND30 + two sealed quotes, un-awarded.
  rfq <- submit p.buyer do
    createCmd RFQ with
      buyer = p.buyer; regulator = p.regulator
      invitedDealers = [p.dealerA, p.dealerB]
      instrument = "TBOND30"; quantity = 1000.0; payInstrument = "USDC"
      assetIssuer = Some p.bondIssuer; payIssuer = Some p.cashIssuer
      deadline = Some (time (date 2030 Jan 1) 0 0 0)
  _ <- submit p.dealerA do
    exerciseCmd rfq SubmitQuote with dealer = p.dealerA; price = 4210000.0; assetCid = bondA
  _ <- submit p.dealerB do
    exerciseCmd rfq SubmitQuote with dealer = p.dealerB; price = 4250000.0; assetCid = bondB
  pure p
