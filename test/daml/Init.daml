-- On-ledger seed for the demo. Run against LocalNet or a Devnet participant:
--   daml script --dar test/.daml/dist/bisik-test-0.1.0.dar \
--     --script-name Init:initialize --ledger-host <host> --ledger-port <port>
-- Allocates the demo parties, mints holdings, and opens one live RFQ with two
-- sealed quotes already submitted -- the exact state the frontend/demo needs.
module Init where

import DA.Foldable (forA_)
import Daml.Script
import Bisik

data Seeded = Seeded
  with
    buyer : Party
    dealerA : Party
    dealerB : Party
    regulator : Party
    rfq : ContractId RFQ
  deriving (Eq, Show)

initialize : Script Seeded
initialize = do
  buyer <- allocateParty "Buyer"
  dealerA <- allocateParty "DealerA"
  dealerB <- allocateParty "DealerB"
  regulator <- allocateParty "Regulator"
  cashIssuer <- allocateParty "CashIssuer"
  bondIssuer <- allocateParty "BondIssuer"

  -- Buyer funded with cash; each dealer holds the bond they can quote.
  _ <- submit cashIssuer do
    createCmd Holding with
      issuer = cashIssuer; owner = buyer; instrument = "USDC"; amount = 5000000.0
  bondA <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerA; instrument = "TBOND30"; amount = 1000.0
  bondB <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerB; instrument = "TBOND30"; amount = 1000.0

  rfq <- submit buyer do
    createCmd RFQ with
      buyer; regulator
      invitedDealers = [dealerA, dealerB]
      instrument = "TBOND30"; quantity = 1000.0; payInstrument = "USDC"

  -- Two sealed quotes so the desk opens with something to award.
  _ <- submit dealerA do
    exerciseCmd rfq SubmitQuote with
      dealer = dealerA; price = 4210000.0; assetCid = bondA
  _ <- submit dealerB do
    exerciseCmd rfq SubmitQuote with
      dealer = dealerB; price = 4250000.0; assetCid = bondB

  forA_ [ ("buyer", buyer), ("dealerA", dealerA), ("dealerB", dealerB)
        , ("regulator", regulator) ] \(label, p) ->
    debug (label <> " = " <> show p)

  pure Seeded with buyer; dealerA; dealerB; regulator; rfq
