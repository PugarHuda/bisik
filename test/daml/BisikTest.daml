-- End-to-end test: mint -> RFQ -> sealed quotes -> Vickrey award (atomic DvP),
-- plus the privacy assertions that ARE the product.
module BisikTest where

import DA.Assert ((===))
import DA.List (sortOn)
import DA.Optional (isNone)
import Daml.Script
import Bisik

testBisik : Script ()
testBisik = do
  buyer <- allocateParty "Buyer"
  dealerA <- allocateParty "DealerA"
  dealerB <- allocateParty "DealerB"
  outsider <- allocateParty "Outsider"
  regulator <- allocateParty "Regulator"
  cashIssuer <- allocateParty "CashIssuer"
  bondIssuer <- allocateParty "BondIssuer"

  -- Mint both legs
  cash <- submit cashIssuer do
    createCmd Holding with
      issuer = cashIssuer; owner = buyer; instrument = "USDC"; amount = 5000000.0
  bondA <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerA; instrument = "TBOND30"; amount = 1000.0
  bondB <- submit bondIssuer do
    createCmd Holding with
      issuer = bondIssuer; owner = dealerB; instrument = "TBOND30"; amount = 1000.0

  -- Buyer opens an RFQ to a chosen two-dealer panel
  rfq <- submit buyer do
    createCmd RFQ with
      buyer; regulator
      invitedDealers = [dealerA, dealerB]
      instrument = "TBOND30"; quantity = 1000.0; payInstrument = "USDC"

  -- An uninvited party cannot quote (cannot even see the RFQ)
  submitMustFail outsider do
    exerciseCmd rfq SubmitQuote with
      dealer = outsider; price = 1.0; assetCid = bondA

  -- Sealed quotes: A asks 4.21M, B asks 4.25M
  quoteA <- submit dealerA do
    exerciseCmd rfq SubmitQuote with
      dealer = dealerA; price = 4210000.0; assetCid = bondA
  quoteB <- submit dealerB do
    exerciseCmd rfq SubmitQuote with
      dealer = dealerB; price = 4250000.0; assetCid = bondB

  -- THE PRODUCT: competing dealers never receive each other's quotes
  qAseenByB <- queryContractId dealerB quoteA
  assertMsg "dealer B must not see dealer A's quote" (isNone qAseenByB)
  qBseenByA <- queryContractId dealerA quoteB
  assertMsg "dealer A must not see dealer B's quote" (isNone qBseenByA)

  -- Regulator sees zero pre-trade flow
  regQuotes <- query @Quote regulator
  regQuotes === []
  regRFQs <- query @RFQ regulator
  regRFQs === []

  -- Award: cheapest ask (A) wins, paid the second price (B's 4.25M) - atomic DvP
  submit buyer do
    exerciseCmd rfq Award with quoteCids = [quoteA, quoteB]; cashCid = cash

  -- Buyer holds the bond + 750k change
  buyerHoldings <- map snd <$> query @Holding buyer
  sortOn fst [(h.instrument, h.amount) | h <- buyerHoldings, h.owner == buyer]
    === [("TBOND30", 1000.0), ("USDC", 750000.0)]

  -- Winning dealer got the Vickrey clearing price, and sold the bond
  dealerAHoldings <- map snd <$> query @Holding dealerA
  [(h.instrument, h.amount) | h <- dealerAHoldings, h.owner == dealerA]
    === [("USDC", 4250000.0)]

  -- Losing dealer keeps their asset, learns nothing
  dealerBHoldings <- map snd <$> query @Holding dealerB
  [(h.instrument, h.amount) | h <- dealerBHoldings, h.owner == dealerB]
    === [("TBOND30", 1000.0)]

  -- Regulator sees exactly one post-trade report at the clearing price
  reports <- map snd <$> query @TradeReport regulator
  [(r.instrument, r.quantity, r.clearingPrice) | r <- reports]
    === [("TBOND30", 1000.0, 4250000.0)]

  pure ()
